  <span class="ei-sep"></span>
  <span class="ei"><span class="ei-ic"><i class="fa-solid fa-envelope"></i></span><span class="ei-txt"><b>Email Us</b><a href="mailto:infoadmittingbmci@gmail.com">infoadmittingbmci@gmail.com</a></span></span>
</div>

<!-- HEADER -->
<header>
  <div class="wrap nav">
    <a class="logo" href="#" onclick="go('home');return false">
      <img class="logo-mark" src="assets/img/logo/logo1.png" alt="BicutanMed logo">
      <img class="logo-text" src="assets/img/logo/bicutanmed-text.webp" alt="BicutanMed">
    </a>
    <ul class="menu" id="menu">
      <li><button data-page="home" class="active" onclick="go('home')">Home</button></li>
      <li><button data-page="services" onclick="go('services')">Services</button></li>
      <li><button data-page="doctors" onclick="go('doctors')">Doctors</button></li>
      <li><button data-page="patients" onclick="go('patients')">Patients &amp; Visitors</button></li>
      <li><button data-page="about" onclick="go('about')">About Us</button></li>
    </ul>
    <div class="nav-cta">
      <button class="btn" onclick="go('feedback')">Book / Feedback</button>
      <button class="hamburger" id="burger" onclick="toggleMenu()" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>

