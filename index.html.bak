<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bicutan Medical Center — Quality Healthcare in Taguig, Open 24/7</title>
<meta name="description" content="Bicutan Medical Center is a 100-bed private hospital in Taguig City, open 24 hours. Expert specialist doctors, modern diagnostics (2D echo, CT scan), and compassionate, affordable care.">
<meta name="keywords" content="Bicutan Medical Center, hospital Taguig, 24/7 hospital, specialist doctors Taguig, emergency room, HMO accredited hospital">
<meta name="author" content="Bicutan Medical Center Inc.">
<meta name="theme-color" content="#157a40">
<meta property="og:type" content="website">
<meta property="og:title" content="Bicutan Medical Center — Caring for Life, 24/7">
<meta property="og:description" content="A 100-bed private hospital in Taguig City with expert specialists and modern facilities. Always open.">
<meta property="og:image" content="assets/img/background/bg1.jpg">
<meta property="og:locale" content="en_PH">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Bicutan Medical Center — Caring for Life, 24/7">
<meta name="twitter:description" content="Quality, compassionate healthcare in Taguig City. Open 24 hours, every day.">
<meta name="twitter:image" content="assets/img/background/bg1.jpg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
<link rel="icon" type="image/png" href="assets/img/logo/logo1.png">
<link rel="apple-touch-icon" href="assets/img/logo/logo1.png">
<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"Hospital",
  "name":"Bicutan Medical Center Inc.",
  "description":"A 100-bed private hospital in Taguig City offering 24/7 expert, compassionate, and affordable healthcare.",
  "image":"assets/img/background/bg1.jpg",
  "url":"https://bicutanmed.com",
  "telephone":"+63285381280",
  "email":"infoadmittingbmci@gmail.com",
  "medicalSpecialty":["Emergency","Cardiology","Pediatrics","Neurology","Radiology","Oncology","Obstetric","Orthopedic","InternalMedicine"],
  "address":{"@type":"PostalAddress","streetAddress":"191 M. L. Quezon Avenue","addressLocality":"Taguig","addressRegion":"Metro Manila","postalCode":"1632","addressCountry":"PH"},
  "openingHoursSpecification":{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],"opens":"00:00","closes":"23:59"},
  "availableService":{"@type":"MedicalProcedure","name":"Emergency Care, 2D Echo, CT Scan, Laboratory, Diagnostics"}
}
</script>
<link rel="preload" as="image" href="assets/img/background/bg1.jpg">
<!-- Analytics: set GA_ID to your GA4 Measurement ID (e.g. 'G-XXXXXXXXXX') to enable. Inert until then. -->
<script>
  window.GA_ID='';
  if(window.GA_ID){
    var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id='+GA_ID;document.head.appendChild(s);
    window.dataLayer=window.dataLayer||[];window.gtag=function(){dataLayer.push(arguments);};gtag('js',new Date());gtag('config',GA_ID);
  }
</script>
<style>
:root{
  --teal:#1f9d55; --teal-dark:#157a40; --teal-light:#e7f6ec;
  --coral:#f4b400; --coral-dark:#d99a00;
  --ink:#16271c; --slate:#5d7065; --mist:#f3faf5; --line:#d8ebde;
  --white:#ffffff; --gold:#f4b400;
  --shadow:0 10px 40px -12px rgba(31,157,85,.25);
  --shadow-sm:0 4px 18px -8px rgba(31,157,85,.22);
  --r:18px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;scrollbar-width:thin;scrollbar-color:var(--teal) var(--teal-light)}
::-webkit-scrollbar{width:12px;height:12px}
::-webkit-scrollbar-track{background:var(--teal-light)}
::-webkit-scrollbar-thumb{background:linear-gradient(var(--teal),var(--teal-dark));border-radius:50px;border:3px solid var(--teal-light)}
::-webkit-scrollbar-thumb:hover{background:var(--teal-dark)}

/* ===== ENHANCEMENTS ===== */
/* Skip link (a11y) */
.skip{position:absolute;left:-999px;top:0;z-index:300;background:var(--teal-dark);color:#fff;padding:12px 20px;border-radius:0 0 12px 0;font-weight:600;font-size:.9rem}
.skip:focus{left:0}
/* Visible keyboard focus */
:focus-visible{outline:3px solid var(--teal);outline-offset:2px;border-radius:4px}
/* Scroll progress bar */
.scroll-prog{position:fixed;top:0;left:0;height:4px;width:0;z-index:300;background:linear-gradient(90deg,var(--teal),var(--coral));box-shadow:0 0 10px rgba(31,157,85,.5);transition:width .1s linear}
/* Back-to-top */
.to-top{position:fixed;bottom:24px;left:24px;z-index:150;width:50px;height:50px;border-radius:50%;background:var(--teal-dark);color:#fff;border:none;cursor:pointer;box-shadow:0 10px 26px -8px rgba(31,157,85,.6);display:grid;place-items:center;font-size:1.1rem;opacity:0;transform:translateY(20px) scale(.8);pointer-events:none;transition:opacity .3s ease,transform .3s cubic-bezier(.34,1.45,.64,1),background .2s}
.to-top.show{opacity:1;transform:none;pointer-events:auto}
.to-top:hover{background:var(--teal);transform:translateY(-3px)}
@media(max-width:480px){.to-top{bottom:88px;left:16px;width:44px;height:44px}}
body{font-family:'Outfit',sans-serif;color:var(--ink);background:var(--white);line-height:1.6;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4{font-family:'Fraunces',serif;line-height:1.1;font-weight:600}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
.wrap{max-width:1180px;margin:0 auto;padding:0 24px}
.btn{display:inline-flex;align-items:center;gap:8px;background:var(--coral);color:var(--ink);padding:13px 26px;border-radius:50px;font-weight:600;font-size:.95rem;border:none;cursor:pointer;transition:.25s;font-family:'Outfit',sans-serif}
.btn:hover{background:var(--coral-dark);transform:translateY(-2px);box-shadow:0 10px 24px -8px rgba(244,180,0,.55)}
.btn-ghost{background:transparent;border:2px solid var(--teal);color:var(--teal)}
.btn-ghost:hover{background:var(--teal);color:#fff;box-shadow:none}

/* ---------- HEADER ---------- */
header{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.92);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
.nav{display:flex;align-items:center;justify-content:space-between;height:94px}
.logo{display:flex;align-items:center;gap:12px}
.logo .logo-mark{width:78px;height:78px;object-fit:contain;flex:none}
.logo .logo-text{height:42px;width:auto;object-fit:contain}
.menu{display:flex;gap:6px;list-style:none}
.menu button{background:none;border:none;font-family:'Outfit';font-size:.9rem;font-weight:500;color:var(--ink);cursor:pointer;padding:9px 15px;border-radius:9px;transition:.2s;letter-spacing:.01em}
.menu button:hover{background:var(--teal-light);color:var(--teal-dark)}
.menu button.active{background:var(--teal);color:#fff}
.nav-cta{display:flex;align-items:center;gap:14px}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px}
.hamburger span{width:26px;height:2.5px;background:var(--ink);border-radius:3px;transition:.3s}

/* ---------- PAGE SYSTEM ---------- */
.page{display:none;animation:fade .5s ease}
.page.active{display:block}
@keyframes fade{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
section{padding:78px 0}
.eyebrow{display:inline-block;color:var(--teal-dark);font-weight:600;font-size:.8rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:14px}
.sec-head{max-width:640px;margin:0 auto 52px;text-align:center}
.sec-head h2{font-size:clamp(2rem,4vw,2.9rem);margin-bottom:14px}
.sec-head p{color:var(--slate);font-size:1.05rem}

/* ---------- HERO ---------- */
.hero{position:relative;background:linear-gradient(160deg,var(--teal-light) 0%,#fff 60%);overflow:hidden;padding:70px 0 56px}
.hero::before{content:"";position:absolute;top:-160px;right:-160px;width:520px;height:520px;background:radial-gradient(circle,rgba(14,124,123,.14),transparent 70%);border-radius:50%}
.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:54px;align-items:center;position:relative}
.hero h1{font-size:clamp(2.4rem,5vw,3.9rem);letter-spacing:-.5px}
.hero h1 em{font-style:italic;color:var(--teal)}
.hero p{color:var(--slate);font-size:1.12rem;margin:22px 0 30px;max-width:480px}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap}
.hero-stats{display:flex;gap:34px;margin-top:46px}
.hero-stats .num{font-family:'Fraunces';font-size:2rem;font-weight:700;color:var(--teal-dark)}
.hero-stats .lbl{font-size:.82rem;color:var(--slate)}
.hero-art{position:relative}
.hero-card{background:#fff;border-radius:24px;overflow:hidden;box-shadow:var(--shadow);position:relative;height:420px}
.hero-card .hero-slide{position:absolute;inset:0;height:100%;width:100%;object-fit:cover;opacity:0;transform:scale(1.04);transition:opacity 1.3s ease,transform 6s ease}
.hero-card .hero-slide.active{opacity:1;transform:scale(1)}
.badge-float{position:absolute;background:#fff;border-radius:16px;padding:14px 18px;box-shadow:var(--shadow-sm);display:flex;align-items:center;gap:12px}
.badge-float .ic{width:42px;height:42px;border-radius:12px;display:grid;place-items:center;color:#fff;flex:none}
.badge-float strong{display:block;font-size:.95rem}
.badge-float span{font-size:.74rem;color:var(--slate)}
.bf1{bottom:30px;left:-26px}
.bf2{top:26px;right:-22px}

/* ---------- FEATURE STRIP ---------- */
.strip{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:-50px;position:relative;z-index:5}
.strip .item{background:#fff;border:1px solid var(--line);border-radius:var(--r);padding:26px 22px;box-shadow:var(--shadow-sm);transition:.25s}
.strip .item:hover{transform:translateY(-6px);box-shadow:var(--shadow)}
.strip .ic{width:50px;height:50px;border-radius:14px;background:var(--teal-light);display:grid;place-items:center;color:var(--teal);margin-bottom:14px}
.strip h4{font-size:1.12rem;margin-bottom:6px}
.strip p{font-size:.88rem;color:var(--slate)}

/* ---------- CARDS GRID ---------- */
.grid{display:grid;gap:26px}
.g3{grid-template-columns:repeat(3,1fr)}
.g4{grid-template-columns:repeat(4,1fr)}
.g2{grid-template-columns:repeat(2,1fr)}
.card{background:#fff;border:1px solid var(--line);border-radius:var(--r);padding:30px 26px;transition:.28s;cursor:default}
.card:hover{transform:translateY(-7px);box-shadow:var(--shadow);border-color:transparent}
.card .ic{width:58px;height:58px;border-radius:16px;display:grid;place-items:center;margin-bottom:18px;background:var(--teal-light);color:var(--teal)}
.card h3{font-size:1.32rem;margin-bottom:10px}
.card p{color:var(--slate);font-size:.94rem}
.card ul{list-style:none;margin-top:14px}
.card li{font-size:.88rem;color:var(--slate);padding:5px 0 5px 24px;position:relative}
.card li::before{content:"";position:absolute;left:0;top:11px;width:13px;height:13px;border-radius:50%;background:var(--teal-light);border:3px solid var(--teal)}

/* ---------- DOCTORS ---------- */
.doc-searchbar{max-width:480px;margin:0 auto 26px;display:flex;align-items:center;gap:11px;background:#fff;border:1.5px solid var(--line);border-radius:50px;padding:5px 8px 5px 20px;box-shadow:var(--shadow-sm);transition:box-shadow .2s ease,border-color .2s ease}
.doc-searchbar:focus-within{border-color:var(--teal);box-shadow:0 0 0 4px rgba(31,157,85,.12)}
.doc-searchbar i{color:var(--teal);font-size:1rem}
.doc-searchbar input{flex:1;border:none;outline:none;background:none;font-family:'Outfit';font-size:.95rem;padding:11px 0;color:var(--ink)}
.doc-searchbar .clr{width:34px;height:34px;border-radius:50%;border:none;background:var(--mist);color:var(--slate);cursor:pointer;flex:none;transition:.2s;display:none}
.doc-searchbar .clr.show{display:grid;place-items:center}
.doc-searchbar .clr:hover{background:var(--line);color:var(--ink)}
.pagination{display:flex;justify-content:center;align-items:center;gap:8px;margin-top:46px;flex-wrap:wrap}
.pg-btn{min-width:42px;height:42px;padding:0 14px;border:1.5px solid var(--line);background:#fff;border-radius:11px;font-family:'Outfit';font-weight:600;font-size:.92rem;color:var(--slate);cursor:pointer;transition:.2s}
.pg-btn:hover:not(:disabled){border-color:var(--teal);color:var(--teal-dark);transform:translateY(-2px)}
.pg-btn.active{background:var(--teal);color:#fff;border-color:var(--teal)}
.pg-btn:disabled{opacity:.4;cursor:not-allowed}
.filter-bar{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-bottom:44px}
.filter-bar button{background:#fff;border:1.5px solid var(--line);padding:9px 20px;border-radius:50px;font-family:'Outfit';font-weight:500;font-size:.86rem;cursor:pointer;transition:.2s;color:var(--slate)}
.filter-bar button.active,.filter-bar button:hover{background:var(--teal);color:#fff;border-color:var(--teal)}
.doc-card{background:#fff;border:1px solid var(--line);border-radius:20px;overflow:hidden;transition:.28s}
.doc-card:hover{transform:translateY(-7px);box-shadow:var(--shadow)}
.doc-photo{height:240px;background:linear-gradient(135deg,var(--teal-light),#fff);position:relative;overflow:hidden}
.doc-photo img{height:100%;width:100%;object-fit:cover}
.doc-tag{position:absolute;top:14px;left:14px;background:rgba(255,255,255,.95);color:var(--teal-dark);font-size:.72rem;font-weight:600;padding:5px 12px;border-radius:50px}
.doc-body{padding:22px}
.doc-body h3{font-size:1.22rem}
.doc-spec{color:var(--teal-dark);font-weight:600;font-size:.85rem;margin:4px 0 10px}
.doc-body p{font-size:.85rem;color:var(--slate);margin-bottom:14px}
.doc-meta{display:flex;gap:16px;font-size:.78rem;color:var(--slate);border-top:1px solid var(--line);padding-top:14px}
.doc-meta b{color:var(--ink)}

/* ---------- PATIENTS / accordion + info ---------- */
.split{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:start}
.accordion .ac-item{border:1px solid var(--line);border-radius:14px;margin-bottom:14px;overflow:hidden;background:#fff}
.accordion .ac-head{padding:18px 22px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:600;font-size:1rem}
.accordion .ac-head:hover{background:var(--mist)}
.accordion .ac-head .pl{font-size:1.4rem;color:var(--teal);transition:.3s}
.accordion .ac-item.open .pl{transform:rotate(45deg)}
.accordion .ac-body{max-height:0;overflow:hidden;transition:max-height .35s ease;color:var(--slate);font-size:.92rem}
.accordion .ac-body p{padding:0 22px 20px}
.info-card{background:var(--teal);color:#fff;border-radius:22px;padding:36px;box-shadow:var(--shadow)}
.info-card h3{font-size:1.5rem;margin-bottom:8px;color:#fff}
.info-card>p{color:rgba(255,255,255,.85);margin-bottom:24px;font-size:.95rem}
.hours-row{display:flex;justify-content:space-between;padding:13px 0;border-bottom:1px solid rgba(255,255,255,.18);font-size:.92rem}
.hours-row:last-child{border:none}
.hours-row span:last-child{color:#ffd9a0;font-weight:600}
.visit-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:30px}
.visit-grid .vc{background:var(--mist);border-radius:16px;padding:24px;text-align:center}
.visit-grid .vc .ic{width:50px;height:50px;margin:0 auto 12px;border-radius:14px;background:#fff;display:grid;place-items:center;color:var(--teal);box-shadow:var(--shadow-sm)}
.visit-grid .vc h4{font-size:1rem;margin-bottom:6px}
.visit-grid .vc p{font-size:.83rem;color:var(--slate)}

/* ---------- ABOUT ---------- */
.about-hero{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:center}
.about-hero img{border-radius:22px;height:430px;width:100%;object-fit:cover;box-shadow:var(--shadow)}
.values{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:54px}
.value{text-align:center;padding:30px 22px;border-radius:var(--r);background:var(--mist)}
.value .ic{width:60px;height:60px;border-radius:50%;background:#fff;display:grid;place-items:center;margin:0 auto 16px;color:var(--teal);box-shadow:var(--shadow-sm)}
.value h4{font-size:1.18rem;margin-bottom:8px}
.value p{font-size:.88rem;color:var(--slate)}
.timeline{max-width:760px;margin:54px auto 0;position:relative;padding-left:34px}
.timeline::before{content:"";position:absolute;left:8px;top:6px;bottom:6px;width:2px;background:var(--line)}
.tl-item{position:relative;padding-bottom:30px}
.tl-item::before{content:"";position:absolute;left:-31px;top:4px;width:16px;height:16px;border-radius:50%;background:var(--coral);border:3px solid #fff;box-shadow:0 0 0 2px var(--coral)}
.tl-item .yr{font-family:'Fraunces';font-weight:700;color:var(--teal-dark);font-size:1.1rem}
.tl-item p{color:var(--slate);font-size:.92rem}

/* ---------- CHAT WIDGET ---------- */
.chat-fab{position:fixed;bottom:24px;right:24px;z-index:150;width:62px;height:62px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--teal-dark));color:#fff;border:none;cursor:pointer;box-shadow:0 12px 30px -8px rgba(31,157,85,.6);display:grid;place-items:center;font-size:1.5rem;transition:transform .25s ease}
.chat-fab:hover{transform:scale(1.08)}
.chat-fab .fa-xmark{display:none}
.chat-open .chat-fab .fa-comment-dots{display:none}
.chat-open .chat-fab .fa-xmark{display:block}
.chat-win{position:fixed;bottom:98px;right:24px;z-index:150;width:372px;max-width:calc(100vw - 32px);height:524px;max-height:calc(100vh - 140px);background:#fff;border-radius:22px;box-shadow:0 30px 70px -18px rgba(0,0,0,.42);display:flex;flex-direction:column;overflow:hidden;opacity:0;transform:translateY(22px) scale(.96);pointer-events:none;transition:opacity .3s ease,transform .35s cubic-bezier(.34,1.45,.64,1)}
.chat-open .chat-win{opacity:1;transform:none;pointer-events:auto}
.chat-head{background:linear-gradient(135deg,var(--teal-dark),var(--teal));color:#fff;padding:16px 20px;display:flex;align-items:center;gap:12px}
.chat-head .ava{width:44px;height:44px;border-radius:50%;background:#fff;display:grid;place-items:center;flex:none;overflow:hidden}
.chat-head .ava img{width:36px;height:36px;object-fit:contain}
.chat-head h4{color:#fff;font-size:1.05rem;font-family:'Outfit';font-weight:600;line-height:1.2}
.chat-head .stat{font-size:.75rem;color:rgba(255,255,255,.85);display:flex;align-items:center;gap:6px}
.chat-head .stat::before{content:"";width:8px;height:8px;border-radius:50%;background:#8affc0;box-shadow:0 0 0 3px rgba(138,255,192,.3)}
.chat-body{flex:1;overflow-y:auto;padding:18px;display:flex;flex-direction:column;gap:11px;background:var(--mist)}
.msg{max-width:82%;padding:11px 15px;border-radius:16px;font-size:.9rem;line-height:1.5;animation:fadeUp .35s ease both;word-wrap:break-word}
.msg.bot{background:#fff;border:1px solid var(--line);border-bottom-left-radius:5px;align-self:flex-start;color:var(--ink)}
.msg.user{background:var(--teal);color:#fff;border-bottom-right-radius:5px;align-self:flex-end}
.msg a{color:var(--teal-dark);font-weight:600;text-decoration:underline;cursor:pointer}
.msg.user a{color:#fff}
.chat-quick{display:flex;flex-wrap:wrap;gap:8px;padding:0 16px 12px;background:var(--mist)}
.chat-quick button{background:#fff;border:1.5px solid var(--teal);color:var(--teal-dark);font-family:'Outfit';font-size:.8rem;font-weight:500;padding:8px 13px;border-radius:50px;cursor:pointer;transition:.2s}
.chat-quick button:hover{background:var(--teal);color:#fff}
.chat-input{display:flex;gap:8px;padding:12px;border-top:1px solid var(--line);background:#fff}
.chat-input input{flex:1;border:1.5px solid var(--line);border-radius:50px;padding:11px 16px;font-family:'Outfit';font-size:.9rem;outline:none;transition:border-color .2s}
.chat-input input:focus{border-color:var(--teal)}
.chat-input button{width:44px;height:44px;border-radius:50%;background:var(--teal);color:#fff;border:none;cursor:pointer;flex:none;transition:.2s}
.chat-input button:hover{background:var(--teal-dark)}
.typing{display:flex!important;gap:4px;align-items:center}
.typing span{width:7px;height:7px;border-radius:50%;background:var(--slate);opacity:.5;animation:chatType 1s infinite}
.typing span:nth-child(2){animation-delay:.2s}
.typing span:nth-child(3){animation-delay:.4s}
@keyframes chatType{0%,100%{transform:translateY(0);opacity:.4}50%{transform:translateY(-5px);opacity:1}}
@media(max-width:480px){.chat-win{bottom:88px;right:16px;left:16px;width:auto;height:72vh}.chat-fab{bottom:18px;right:18px}}

/* ---------- VISION / MISSION / CORE VALUES ---------- */
.vm-grid{display:grid;grid-template-columns:1fr 1fr;gap:26px;margin-top:30px}
.vm-card{border-radius:var(--r);padding:38px 34px;position:relative;overflow:hidden}
.vm-card.vis{background:linear-gradient(150deg,var(--teal-dark),var(--teal));color:#fff}
.vm-card.mis{background:var(--mist);border:1px solid var(--line)}
.vm-card::after{content:"";position:absolute;bottom:-70px;right:-50px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(244,180,0,.18),transparent 70%)}
.vm-card .ic{width:56px;height:56px;border-radius:16px;display:grid;place-items:center;margin-bottom:18px;position:relative}
.vm-card.vis .ic{background:rgba(255,255,255,.18);color:#fff}
.vm-card.mis .ic{background:var(--teal-light);color:var(--teal)}
.vm-card h3{font-size:1.4rem;margin-bottom:10px;position:relative}
.vm-card.vis h3{color:#fff}
.vm-card p{font-size:1rem;line-height:1.6;position:relative}
.vm-card.vis p{color:rgba(255,255,255,.9)}
.vm-card.mis p{color:var(--slate)}
.corevals{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;margin-top:30px}
.cv{background:#fff;border:1px solid var(--line);border-radius:var(--r);padding:30px 24px;text-align:center;transition:transform .32s cubic-bezier(.34,1.56,.64,1),box-shadow .3s ease}
.cv:hover{transform:translateY(-7px);box-shadow:var(--shadow);border-color:transparent}
.cv .letter{width:64px;height:64px;margin:0 auto 16px;border-radius:18px;background:linear-gradient(135deg,var(--teal),var(--teal-dark));color:#fff;font-family:'Fraunces',serif;font-weight:700;font-size:1.9rem;display:grid;place-items:center;box-shadow:var(--shadow-sm)}
.cv h4{font-size:1.05rem;margin-bottom:8px;letter-spacing:.02em}
.cv p{font-size:.86rem;color:var(--slate)}
@media(max-width:860px){.vm-grid{grid-template-columns:1fr}.corevals{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.corevals{grid-template-columns:1fr}}

/* ---------- FEEDBACK FORM ---------- */
.fb-wrap{display:grid;grid-template-columns:.85fr 1.15fr;gap:46px;align-items:start}
.fb-intro h2{font-size:2.3rem;margin-bottom:14px}
.fb-intro p{color:var(--slate);margin-bottom:26px}
.fb-points{list-style:none}
.fb-points li{display:flex;gap:13px;align-items:flex-start;margin-bottom:16px;font-size:.93rem}
.fb-points .ic{width:34px;height:34px;border-radius:10px;background:var(--teal-light);color:var(--teal);display:grid;place-items:center;flex:none}
.form{background:#fff;border:1px solid var(--line);border-radius:22px;padding:36px;box-shadow:var(--shadow-sm)}
.field{margin-bottom:20px}
.field label{display:block;font-size:.85rem;font-weight:600;margin-bottom:7px}
.field input,.field select,.field textarea{width:100%;padding:13px 15px;border:1.5px solid var(--line);border-radius:11px;font-family:'Outfit';font-size:.93rem;color:var(--ink);background:var(--mist);transition:.2s}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--teal);background:#fff;box-shadow:0 0 0 4px rgba(14,124,123,.1)}
.field textarea{resize:vertical;min-height:110px}
.field.err input,.field.err select,.field.err textarea{border-color:var(--coral)}
.err-msg{color:var(--coral-dark);font-size:.78rem;margin-top:5px;display:none}
.field.err .err-msg{display:block}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.stars{display:flex;gap:8px;font-size:1.9rem}
.stars span{cursor:pointer;color:var(--line);transition:.15s;line-height:1}
.stars span.on,.stars span:hover{color:var(--gold);transform:scale(1.1)}
.form-success{display:none;text-align:center;padding:30px 10px}
.form-success .check{width:74px;height:74px;border-radius:50%;background:var(--teal-light);color:var(--teal);display:grid;place-items:center;margin:0 auto 18px}
.form-success h3{font-size:1.6rem;margin-bottom:8px}
.form-success p{color:var(--slate)}

/* ---------- CTA BANNER ---------- */
.cta-banner{background:linear-gradient(135deg,var(--teal-dark),var(--teal));border-radius:28px;padding:56px;text-align:center;color:#fff;position:relative;overflow:hidden}
.cta-banner::before{content:"";position:absolute;top:-80px;right:-60px;width:300px;height:300px;background:radial-gradient(circle,rgba(255,255,255,.12),transparent 70%);border-radius:50%}
.cta-banner h2{font-size:clamp(1.8rem,4vw,2.6rem);color:#fff;margin-bottom:12px;position:relative}
.cta-banner p{color:rgba(255,255,255,.85);max-width:520px;margin:0 auto 28px;position:relative}
.cta-banner .btn{position:relative;background:#fff;color:var(--teal-dark)}
.cta-banner .btn:hover{background:var(--gold);color:var(--ink)}

/* ---------- FOOTER ---------- */
footer{background:var(--ink);color:rgba(255,255,255,.75);padding:64px 0 26px;margin-top:0}
.foot-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1.2fr;gap:40px;margin-bottom:44px}
.foot-grid .logo{color:#fff;margin-bottom:16px;display:inline-flex;align-items:center;gap:12px;flex-wrap:nowrap}
.foot-grid .logo small{color:rgba(255,255,255,.55)}
.foot-grid .logo .logo-mark{width:58px;height:58px}
.foot-grid .logo .logo-word{font-family:'Fraunces',serif;font-weight:700;font-size:1.5rem;color:#fff;letter-spacing:-.01em;white-space:nowrap}
.foot-col h5{color:#fff;font-family:'Outfit';font-size:.95rem;margin-bottom:16px;letter-spacing:.04em}
.foot-col a{cursor:pointer}
.foot-col a,.foot-col p{display:block;font-size:.88rem;margin-bottom:10px;transition:.2s;color:rgba(255,255,255,.7)}
.foot-col a:hover{color:var(--gold);padding-left:4px}
.foot-bottom{border-top:1px solid rgba(255,255,255,.12);padding-top:24px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:.82rem;color:rgba(255,255,255,.5)}
.emergency{background:linear-gradient(90deg,#0d5a2f,#13713c,#0d5a2f);background-size:200% 100%;animation:gradientShift 16s ease infinite;color:#fff;padding:9px 16px;font-size:.85rem;font-weight:500;display:flex;justify-content:center;align-items:center;gap:10px 14px;flex-wrap:wrap}
.emergency .ei{display:inline-flex;align-items:center;gap:11px;padding:5px 10px;border-radius:50px;transition:background .2s ease}
.emergency .ei:hover{background:rgba(255,255,255,.12)}
.emergency .ei .ei-ic{width:30px;height:30px;border-radius:50%;background:var(--gold);display:grid;place-items:center;flex:none;box-shadow:0 2px 6px -1px rgba(0,0,0,.3)}
.emergency .ei .ei-ic i{color:#0d5a2f;font-size:.85rem}
.emergency .ei .ei-txt{display:flex;flex-direction:column;line-height:1.2;text-align:left}
.emergency .ei .ei-txt b{font-weight:600;font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:#ffe1a8}
.emergency .ei a{font-weight:700;text-decoration:none;color:#fff;font-size:.88rem}
.emergency .ei a:hover{color:#ffe1a8}
.emergency .ei-sep{width:1px;height:28px;background:rgba(255,255,255,.25)}
@media(max-width:680px){.emergency{gap:4px 10px}.emergency .ei-sep{display:none}}

/* ---------- RESPONSIVE ---------- */
@media(max-width:980px){
  .hero-grid,.split,.fb-wrap,.about-hero{grid-template-columns:1fr;gap:40px}
  .g4{grid-template-columns:repeat(2,1fr)}
  .strip{grid-template-columns:repeat(2,1fr)}
  .foot-grid{grid-template-columns:1fr 1fr;gap:30px}
  .hero-card{height:340px}
  .bf1{left:10px}.bf2{right:10px}
}
@media(max-width:720px){
  .menu{position:fixed;top:94px;left:0;right:0;background:#fff;flex-direction:column;padding:16px;gap:4px;border-bottom:1px solid var(--line);box-shadow:var(--shadow);transform:translateY(-130%);transition:transform .35s ease;z-index:90}
  .menu.show{transform:translateY(0)}
  .menu button{width:100%;text-align:left;padding:14px 16px;font-size:1rem}
  .hamburger{display:flex}
  .nav-cta .btn{padding:10px 16px;font-size:.84rem}
  .hamburger.open span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}
  .hamburger.open span:nth-child(2){opacity:0}
  .hamburger.open span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}
}
@media(max-width:560px){
  section{padding:54px 0}
  .g3,.g2,.g4,.values,.visit-grid,.strip{grid-template-columns:1fr}
  .row2{grid-template-columns:1fr}
  .hero-stats{gap:22px;flex-wrap:wrap}
  .cta-banner,.info-card,.form{padding:30px 22px}
  .wrap{padding:0 18px}
  .foot-grid{grid-template-columns:1fr}
}

/* ---------- FIND YOUR DOCTOR SEARCH ---------- */
.docsearch{margin-top:8px;background:linear-gradient(135deg,var(--teal-dark),var(--teal));border-radius:26px;padding:38px 42px;box-shadow:var(--shadow);position:relative;overflow:hidden}
.docsearch::before{content:"";position:absolute;top:-90px;right:-70px;width:300px;height:300px;background:radial-gradient(circle,rgba(255,255,255,.12),transparent 70%);border-radius:50%}
.docsearch::after{content:"";position:absolute;bottom:-110px;left:-60px;width:260px;height:260px;background:radial-gradient(circle,rgba(244,180,0,.16),transparent 70%);border-radius:50%}
.ds-head{position:relative;margin-bottom:24px}
.ds-head .eyebrow{color:#ffd9a0;margin-bottom:8px}
.ds-head h3{color:#fff;font-size:clamp(1.5rem,3vw,2rem);margin-bottom:6px}
.ds-head p{color:rgba(255,255,255,.85);font-size:.96rem}
.ds-form{position:relative;display:grid;grid-template-columns:1.4fr 1fr auto;gap:14px;align-items:stretch}
.ds-input{display:flex;align-items:center;background:#fff;border-radius:13px;padding:0 16px;gap:11px;transition:box-shadow .2s ease}
.ds-input:focus-within{box-shadow:0 0 0 4px rgba(255,255,255,.35)}
.ds-input svg{color:var(--teal);flex:none}
.ds-input input,.ds-input select{border:none;outline:none;background:none;width:100%;padding:16px 0;font-family:'Outfit';font-size:.95rem;color:var(--ink);cursor:pointer}
.ds-input input{cursor:text}
.ds-form .btn{padding:0 32px;white-space:nowrap;justify-content:center}
@media(max-width:760px){.ds-form{grid-template-columns:1fr}.ds-form .btn{padding:15px}}

/* ---------- HMO PARTNERS ---------- */
.hmo-sec{background:var(--mist);overflow:hidden}
.hmo-marquee{position:relative;overflow:hidden;-webkit-mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent);mask-image:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent)}
.hmo-marquee::-webkit-scrollbar{display:none}
.hmo-track{display:flex;gap:22px;width:max-content;animation:hmoScroll 48s linear infinite}
.hmo-marquee.rev .hmo-track{animation-direction:reverse;animation-duration:54s}
.hmo-marquee:hover .hmo-track{animation-play-state:paused}
.hmo-logo{flex:none;width:170px;height:96px;background:#fff;border:1px solid var(--line);border-radius:16px;display:flex;align-items:center;justify-content:center;padding:16px 22px;box-shadow:var(--shadow-sm);transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s ease}
.hmo-logo img{width:auto;height:auto;max-width:100%;max-height:52px;object-fit:contain;object-position:center;filter:grayscale(1);opacity:.7;transition:filter .35s ease,opacity .35s ease,transform .35s ease}
.hmo-logo:hover{transform:translateY(-6px);box-shadow:var(--shadow)}
.hmo-logo:hover img{filter:grayscale(0);opacity:1;transform:scale(1.06)}
@keyframes hmoScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@media(max-width:560px){.hmo-logo{width:140px;height:82px;padding:14px 18px}}

/* ---------- TESTIMONIALS ---------- */
.testi-sec{background:linear-gradient(160deg,var(--mist),#fff)}
.testi-wrap{position:relative;max-width:780px;margin:0 auto;min-height:230px}
.testi{position:absolute;inset:0;background:#fff;border:1px solid var(--line);border-radius:24px;padding:42px 44px;box-shadow:var(--shadow-sm);text-align:center;opacity:0;transform:translateY(18px) scale(.97);transition:opacity .5s ease,transform .5s ease;pointer-events:none}
.testi.active{opacity:1;transform:none;pointer-events:auto;position:relative}
.testi .quote-ic{width:54px;height:54px;margin:0 auto 18px;border-radius:50%;background:var(--teal-light);color:var(--teal);display:grid;place-items:center}
.testi p{font-size:1.12rem;color:var(--ink);line-height:1.7;font-style:italic;margin-bottom:22px}
.testi .stars-row{color:var(--gold);font-size:1.05rem;letter-spacing:2px;margin-bottom:14px}
.testi .who{display:flex;align-items:center;justify-content:center;gap:12px}
.testi .who .av{width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--teal-dark));color:#fff;font-family:'Fraunces',serif;font-weight:700;display:grid;place-items:center;font-size:1.15rem}
.testi .who b{display:block;font-size:.98rem}
.testi .who span{font-size:.82rem;color:var(--slate)}
.testi-dots{display:flex;justify-content:center;gap:9px;margin-top:28px}
.testi-dots button{width:11px;height:11px;border-radius:50%;border:none;background:var(--line);cursor:pointer;transition:.25s;padding:0}
.testi-dots button.on{background:var(--teal);transform:scale(1.25)}
@media(max-width:560px){.testi{padding:32px 24px}.testi p{font-size:1rem}}

/* ---------- FACILITIES GALLERY ---------- */
.facility-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.fac{position:relative;border-radius:var(--r);overflow:hidden;aspect-ratio:4/3;box-shadow:var(--shadow-sm);cursor:pointer}
.fac img{width:100%;height:100%;object-fit:cover;transition:transform .55s ease}
.fac:hover img{transform:scale(1.09)}
.fac::after{content:"";position:absolute;inset:0;background:linear-gradient(transparent 50%,rgba(13,40,25,.55));opacity:0;transition:opacity .35s ease}
.fac:hover::after{opacity:1}
.fac .fac-cap{position:absolute;left:14px;bottom:12px;color:#fff;font-family:'Outfit';font-weight:600;font-size:.9rem;z-index:2;opacity:0;transform:translateY(8px);transition:.35s ease}
.fac:hover .fac-cap{opacity:1;transform:none}
@media(max-width:860px){.facility-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.facility-grid{grid-template-columns:1fr}}

/* ---------- LOCATION / MAP ---------- */
.map-wrap{display:grid;grid-template-columns:.95fr 1.05fr;gap:0;border-radius:26px;overflow:hidden;box-shadow:var(--shadow);border:1px solid var(--line)}
.map-info{background:linear-gradient(160deg,var(--teal-dark),var(--teal));color:#fff;padding:48px 44px;position:relative;overflow:hidden}
.map-info::before{content:"";position:absolute;bottom:-90px;left:-70px;width:280px;height:280px;background:radial-gradient(circle,rgba(255,255,255,.10),transparent 70%);border-radius:50%}
.map-info h3{color:#fff;font-size:1.9rem;margin-bottom:10px;position:relative}
.map-info>p{color:rgba(255,255,255,.85);font-size:.98rem;margin-bottom:28px;position:relative}
.map-detail{display:flex;gap:13px;align-items:center;margin-bottom:15px;position:relative}
.map-detail .ic{width:40px;height:40px;border-radius:12px;background:rgba(255,255,255,.15);display:grid;place-items:center;color:#fff;flex:none;backdrop-filter:blur(4px)}
.map-detail h4{font-family:'Outfit';font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;color:#ffd9a0;margin-bottom:3px;font-weight:600}
.map-detail p{font-size:.96rem;color:#fff;line-height:1.45}
.map-detail a{color:#fff}
.map-detail a:hover{color:#ffd9a0}
.map-static{display:block;position:relative;margin:0 0 26px;border-radius:16px;overflow:hidden;border:2px solid rgba(255,255,255,.3);box-shadow:0 10px 30px -12px rgba(0,0,0,.4);cursor:pointer}
.map-static img{width:100%;height:400px;object-fit:cover;display:block;transition:transform .5s ease}
.map-static:hover img{transform:scale(1.06)}
.map-static{transition:transform .18s ease,border-color .25s ease}
.map-static:hover{border-color:rgba(255,255,255,.7)}
.map-static:active{transform:scale(.97)}
.map-static .pin{position:absolute;bottom:10px;left:12px;background:linear-gradient(135deg,var(--teal),var(--teal-dark));color:#fff;font-size:.74rem;font-weight:600;padding:6px 13px;border-radius:50px;box-shadow:0 4px 12px -3px rgba(0,0,0,.4);display:flex;align-items:center;gap:6px}
.map-static .map-open{position:absolute;top:10px;right:10px;width:34px;height:34px;border-radius:10px;background:rgba(255,255,255,.92);color:var(--teal-dark);display:grid;place-items:center;box-shadow:var(--shadow-sm);transition:transform .25s ease,background .25s ease}
.map-static:hover .map-open{transform:scale(1.12);background:var(--gold);color:var(--ink)}

/* ---------- LIGHTBOX ---------- */
.lightbox{position:fixed;inset:0;z-index:200;background:rgba(10,25,16,.82);backdrop-filter:blur(6px);display:none;place-items:center;padding:28px;opacity:0;transition:opacity .3s ease}
.lightbox.show{display:grid;opacity:1}
.lightbox-inner{position:relative;max-width:960px;width:100%}
.lightbox.show .lightbox-inner{animation:popIn .55s cubic-bezier(.34,1.56,.64,1) both}
.lightbox.show .lightbox-close{animation:popIn .5s cubic-bezier(.34,1.7,.64,1) both .15s}
.lightbox.show .lightbox-cap{animation:popCap .45s ease both .3s}
.lightbox-inner img{width:100%;max-height:80vh;object-fit:contain;border-radius:18px;box-shadow:0 30px 80px -20px rgba(0,0,0,.6)}
.lightbox-close{position:absolute;top:-16px;right:-16px;width:44px;height:44px;border-radius:50%;border:none;background:#fff;color:var(--ink);font-size:1.7rem;line-height:1;cursor:pointer;box-shadow:var(--shadow);transition:.2s;display:grid;place-items:center}
.lightbox-close:hover{background:var(--coral);color:#fff;transform:rotate(90deg)}
.lightbox-cap{margin-top:16px;text-align:center;color:#fff;font-size:.92rem;font-weight:500;display:flex;align-items:center;justify-content:center;gap:8px}
.lightbox-cap svg{color:var(--gold)}
@media(max-width:560px){.lightbox-close{top:-8px;right:-8px;width:38px;height:38px}}
.lb-nav{position:absolute;top:50%;transform:translateY(-50%);width:48px;height:48px;border-radius:50%;border:none;background:rgba(255,255,255,.92);color:var(--ink);font-size:1.8rem;line-height:1;cursor:pointer;display:grid;place-items:center;box-shadow:var(--shadow);transition:background .2s,transform .2s;z-index:3}
.lb-nav:hover{background:var(--teal);color:#fff;transform:translateY(-50%) scale(1.12)}
.lb-nav.prev{left:-22px}
.lb-nav.next{right:-22px}
@media(max-width:560px){.lb-nav{width:42px;height:42px;background:rgba(255,255,255,.85)}.lb-nav.prev{left:6px}.lb-nav.next{right:6px}}
.map-info .btn{position:relative;margin-top:8px;background:#fff;color:var(--teal-dark)}
.map-info .btn:hover{background:var(--gold);color:var(--ink)}
.map-frame{position:relative;min-height:430px}
.map-frame iframe{position:absolute;inset:0;width:100%;height:100%;border:0;filter:saturate(1.05)}
.map-frame .map-static{position:absolute;inset:0;margin:0;height:100%;border:0;border-radius:0}
.map-frame .map-static img{height:100%}
@media(max-width:860px){.map-wrap{grid-template-columns:1fr}.map-frame{min-height:340px;order:2}.map-info{order:1}}

/* ===== KEYFRAMES ===== */
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
@keyframes fadeDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:none}}
@keyframes slideInR{from{opacity:0;transform:translateX(-36px)}to{opacity:1;transform:none}}
@keyframes slideInL{from{opacity:0;transform:translateX(36px)}to{opacity:1;transform:none}}
@keyframes scaleIn{from{opacity:0;transform:scale(.88)}to{opacity:1;transform:none}}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes logoPulse{0%,100%{box-shadow:0 0 0 0 rgba(31,157,85,.35)}60%{box-shadow:0 0 0 14px rgba(31,157,85,0)}}
@keyframes pageIn{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}
@keyframes pinPulse{0%,100%{box-shadow:0 4px 12px -3px rgba(0,0,0,.4),0 0 0 0 rgba(31,157,85,.55)}60%{box-shadow:0 4px 12px -3px rgba(0,0,0,.4),0 0 0 13px rgba(31,157,85,0)}}
@keyframes gradientShift{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
@keyframes shimmer{from{left:-60%}to{left:140%}}
@keyframes floatSoft{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes popIn{0%{opacity:0;transform:scale(.4) translateY(40px)}55%{opacity:1;transform:scale(1.06) translateY(0)}75%{transform:scale(.97)}100%{transform:scale(1)}}
@keyframes popCap{0%{opacity:0;transform:translateY(14px)}100%{opacity:1;transform:translateY(0)}}
@keyframes facSlideNext{0%{opacity:0;transform:translateX(80px)}100%{opacity:1;transform:translateX(0)}}
@keyframes facSlidePrev{0%{opacity:0;transform:translateX(-80px)}100%{opacity:1;transform:translateX(0)}}

/* ===== CHROME ENTRANCE ===== */
.emergency{animation:fadeDown .55s cubic-bezier(.16,1,.3,1) both}
header{animation:fadeDown .55s cubic-bezier(.16,1,.3,1) both .1s}
.logo .mark{animation:logoPulse 3.5s ease-in-out infinite 3s}

/* ===== HERO ENTRANCE (staggered) ===== */
.hero .eyebrow{animation:slideInR .7s cubic-bezier(.16,1,.3,1) both .2s}
.hero h1{animation:fadeUp .8s cubic-bezier(.16,1,.3,1) both .35s}
.hero-grid>div:first-child>p{animation:fadeUp .7s cubic-bezier(.16,1,.3,1) both .55s}
.hero-actions{animation:fadeUp .7s cubic-bezier(.16,1,.3,1) both .7s}
.hero-stats{animation:fadeUp .7s cubic-bezier(.16,1,.3,1) both .9s}
.hero-art{animation:slideInL .9s cubic-bezier(.16,1,.3,1) both .4s}
.bf1{animation:fadeUp .6s cubic-bezier(.16,1,.3,1) both 1s,floatY 4s ease-in-out infinite 2s}
.bf2{animation:fadeUp .6s cubic-bezier(.16,1,.3,1) both 1.15s,floatY 4s ease-in-out infinite 2.5s}

/* ===== PAGE TRANSITION ===== */
.page.active{animation:pageIn .45s cubic-bezier(.16,1,.3,1)}

/* ===== ADDED ANIMATIONS ===== */
/* Button shine sweep on hover */
.btn{position:relative;overflow:hidden}
.btn::after{content:"";position:absolute;top:0;left:-60%;width:45%;height:100%;background:linear-gradient(120deg,transparent,rgba(255,255,255,.5),transparent);transform:skewX(-20deg);pointer-events:none}
.btn:hover::after{animation:shimmer .75s ease}
/* Animated gradient backgrounds */
.cta-banner,.docsearch,.map-info,.info-card{background-size:200% 200%;animation:gradientShift 14s ease infinite}
/* Pulsing green map pin */
.map-static .pin{animation:pinPulse 2.6s ease-in-out infinite 1.4s}
/* Map expand icon gentle float */
.map-static .map-open{animation:floatSoft 3.5s ease-in-out infinite}
/* Icon pop on card / strip / value hover */
.card .ic,.strip .item .ic,.value .ic,.visit-grid .vc .ic{transition:transform .4s cubic-bezier(.34,1.56,.64,1)}
.card:hover .ic,.strip .item:hover .ic,.value:hover .ic,.visit-grid .vc:hover .ic{transform:scale(1.14) rotate(-6deg)}
/* Doctor cards: photo zoom on hover */
.doc-photo img{transition:transform .5s ease}
.doc-card:hover .doc-photo img{transform:scale(1.07)}
@media(prefers-reduced-motion:reduce){*{animation-duration:.001ms!important;animation-iteration-count:1!important;transition-duration:.001ms!important}}

/* ===== SCROLL REVEAL CLASSES ===== */
.rv{opacity:0;transform:translateY(26px);transition:opacity .65s ease,transform .65s ease}
.rv.in{opacity:1;transform:none}
.rv-l{opacity:0;transform:translateX(-30px);transition:opacity .7s ease,transform .7s ease}
.rv-l.in{opacity:1;transform:none}
.rv-r{opacity:0;transform:translateX(30px);transition:opacity .7s ease,transform .7s ease}
.rv-r.in{opacity:1;transform:none}
.rv-s{opacity:0;transform:scale(.9);transition:opacity .6s ease,transform .6s ease}
.rv-s.in{opacity:1;transform:scale(1)}

/* ===== ENHANCED HOVER TRANSITIONS ===== */
.card{transition:transform .32s cubic-bezier(.34,1.56,.64,1),box-shadow .3s ease,border-color .3s ease}
.doc-card{transition:transform .32s cubic-bezier(.34,1.56,.64,1),box-shadow .3s ease}
.strip .item{transition:transform .32s cubic-bezier(.34,1.56,.64,1),box-shadow .3s ease}
.btn{transition:background .25s ease,transform .25s cubic-bezier(.34,1.56,.64,1),box-shadow .25s ease}
.filter-bar button{transition:background .2s ease,color .2s ease,border-color .2s ease,transform .2s cubic-bezier(.34,1.56,.64,1)}
.filter-bar button:hover:not(.active){transform:translateY(-2px)}
.menu button:not(.active):hover{transform:translateX(4px)}
.ac-head{transition:background .2s ease}
.doc-photo img{transition:transform .45s ease}
.doc-card:hover .doc-photo img{transform:scale(1.06)}
.value{transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s ease}
.value:hover{transform:translateY(-6px);box-shadow:var(--shadow)}
.foot-col a{transition:color .2s ease,padding-left .2s ease,transform .2s ease}
</style>
</head>
<body>

